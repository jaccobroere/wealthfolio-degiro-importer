{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "react", "react-dom"]
  },
  // T03: the pure core (src/domain, src/parser, src/mapping, src/validation,
  // src/duplicates, src/reconciliation), the inspector script, and the test
  // suite type-check under these strict settings. The legacy SDK 3.3 UI
  // (src/addon.tsx, src/components/**, src/types.ts) is rewritten in T06; until
  // then it is excluded so the pure core type-checks cleanly on its own.
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.acceptance.config.ts",
    "src/domain/**/*.ts",
    "src/parser/**/*.ts",
    "src/mapping/**/*.ts",
    "src/validation/**/*.ts",
    "src/duplicates/**/*.ts",
    "src/reconciliation/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "dist/**",
    "node_modules/**",
    "src/addon.tsx",
    "src/components/**",
    "src/types.ts"
  ]
}
