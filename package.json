{
  "name": "wealthfolio-degiro-importer",
  "version": "1.2.2",
  "type": "module",
  "description": "Wealthfolio addon for importing DEGIRO account statements",
  "engines": {
    "node": ">=22"
  },
  "author": "shuisman; port maintained by Jacco Broere",
  "license": "MIT",
  "packageManager": "pnpm@10.34.5",
  "keywords": [
    "wealthfolio",
    "degiro",
    "importer",
    "addon",
    "finance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jaccobroere/wealthfolio-degiro-importer.git"
  },
  "homepage": "https://github.com/jaccobroere/wealthfolio-degiro-importer#readme",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "dev:server": "wealthfolio dev",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:acceptance": "playwright test -c playwright.config.ts --grep @acceptance",
    "test:watch": "vitest",
    "inspect:csv": "tsx scripts/inspect-csv.ts",
    "acceptance:local": "vitest run -c vitest.acceptance.config.ts",
    "check:fixtures": "tsx scripts/check-fixtures.ts",
    "validate:manifest": "tsx scripts/validate-manifest.ts",
    "package:addon": "sh scripts/package-addon.sh",
    "validate:package": "tsx scripts/validate-package.ts",
    "privacy:scan": "sh scripts/privacy-scan.sh",
    "release:attestation": "tsx scripts/write-release-attestation.ts",
    "integration:up": "docker compose --project-name wf-degiro-addon-test --env-file tests/integration/.env.example -f tests/integration/compose.yml up --detach --wait",
    "integration:down": "docker compose --project-name wf-degiro-addon-test --env-file tests/integration/.env.example -f tests/integration/compose.yml down --volumes --remove-orphans",
    "verify": "pnpm format && pnpm lint && pnpm type-check && pnpm test && pnpm build && pnpm check:fixtures && pnpm privacy:scan && pnpm validate:manifest && pnpm package:addon && pnpm validate:package",
    "verify:release": "sh scripts/verify-release.sh"
  },
  "dependencies": {
    "decimal.js": "10.6.0",
    "papaparse": "5.5.4"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@wealthfolio/addon-sdk": "^3.6.0",
    "@wealthfolio/ui": "^3.6.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@wealthfolio/addon-dev-tools": "^3.6.0",
    "@wealthfolio/addon-sdk": "~3.6.1",
    "@wealthfolio/ui": "^3.6.0",
    "date-fns": "^4.4.0",
    "decimal.js": "10.6.0",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "papaparse": "5.5.4",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
