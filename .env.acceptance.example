# Local acceptance-test statement path.
# Copy this file to `.env` (gitignored) and set the absolute path to your real
# DEGIRO Account.csv export. The acceptance suite (pnpm acceptance:local) reads
# ONLY this variable and never copies the file into the repository.
#
# Env var: DEGIRO_ACCEPTANCE_CSV
# Example:
#   DEGIRO_ACCEPTANCE_CSV=/absolute/path/to/your/Account.csv
DEGIRO_ACCEPTANCE_CSV=/absolute/path/to/your/Account.csv
